# GitHub Actions Secrets
# These go into GitHub repo Settings > Secrets > Actions (NOT as a file)
# This file is just a reference for what values you need.

# GCP VM external IP address (e.g., 34.71.123.45)
GCP_VM_IP=

# SSH private key for connecting to the VM (the full key including BEGIN/END lines)
GCP_SSH_PRIVATE_KEY=

# SSH username on the VM (usually your Gmail username before the @)
GCP_SSH_USER=

# n8n API key (generate in n8n UI: Settings > API > Add API Key)
N8N_API_KEY=
