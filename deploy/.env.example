# GCP VM Production Environment
# Copy this to .env and fill in real values: cp .env.example .env

# VM external IP (auto-detected by setup.sh, but you can set manually)
VM_IP=

# n8n basic auth (protects the n8n web UI)
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# Gemini API key (free from https://aistudio.google.com/apikey)
GEMINI_API_KEY=
